# VIVA Workbox — Rockville install secrets
#
# This template documents the values install.ps1 expects to find in:
#   /Bob Campbell Working Folder/VIVA Corner Projection/secrets/rockville-workbox.env
# (within Box, which syncs to C:\Users\<user>\Box\... on the Rockville machine)
#
# Restrict access in Box to: Bob + Manfred.
# DO NOT commit a populated copy of this file to git. The repo's .gitignore
# excludes everything matching .env so accidents are unlikely, but be careful.

# === Required ===

# 64 hex chars. Generate fresh:
#   macOS/Linux:  openssl rand -hex 32
#   Windows:      -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
CCWORKBOX_TOKEN=__GENERATE_64_HEX__

# Anthropic API key the service uses to drive Claude Code sessions.
ANTHROPIC_API_KEY=sk-ant-__REPLACE_ME__

# One-time Tailscale auth key. Generate at:
#   https://login.tailscale.com/admin/settings/keys
# Recommended: pre-authorized, ephemeral=false, reusable=false, tagged appropriately.
# REPLACE the placeholder below before running install.ps1, or the installer will refuse to proceed.
TAILSCALE_AUTHKEY=__FILL_IN_BEFORE_INSTALL__

# Path on the Rockville machine to the Box folder Workbox reads content from.
# Manfred-specific. Example shown — adjust to actual username and folder layout.
BOX_CONTENT_PATH=C:\Users\manfred\Box\Bob Campbell Working Folder\VIVA Corner Projection\content\active

# === Optional (defaults applied by installer if omitted) ===
# WORKBOX_DIR=C:\ProgramData\workbox\state
# WORKBOX_PORT=4014
# WORKBOX_BIND_HOST=127.0.0.1
# TASK_TIMEOUT_MS=1800000
